def check_sensitive_paths(target):
    section("SENSITIVE FILE & ENDPOINT EXPOSURE")
    base = target.rstrip("/")
    findings = []

    def probe(path):
        url = base + path
        r = fetch(url, timeout=6)
        if r["status"] in [200, 206]:
            size = len(r["body"])
            snippet = r["body"][:80].replace("\n", " ").strip()
            return {"path": path, "status": r["status"], "size": size, "snippet": snippet}
        return None

    info(f"Probing {len(SENSITIVE_PATHS)} sensitive paths...")
    found_count = 0
    with ThreadPoolExecutor(max_workers=30) as ex:
        futures = {ex.submit(probe, p): p for p in SENSITIVE_PATHS}
        for f in as_completed(futures):
            res = f.result()
            if res:
                found_count += 1
                msg = f"{res['path']} ({res['status']}, {res['size']}b) → {res['snippet']}"
                if any(x in res["path"] for x in [".git", ".env", ".sql", "actuator/env"]):
                    vuln(msg); sev = "CRITICAL"
                elif any(x in res["path"] for x in ["swagger", "graphiql", "phpinfo", "adminer"]):
                    high(msg); sev = "HIGH"
                else:
                    med(msg); sev = "MED"
                findings.append({**res, "severity": sev})

    if found_count == 0:
        ok("No sensitive files exposed")
    else:
        warn(f"Found {found_count} exposed path(s)!")
    return findings


