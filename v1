def check_cookies(target):
    section("COOKIE SECURITY AUDIT")
    findings = []
    r = fetch(target)
    
    raw_cookies = [v for k, v in r["headers"].items() if k.lower() == "set-cookie"]
    
    if not raw_cookies:
        warn("No cookies set on initial request — try an authenticated path")
        return findings
    
    for cookie in raw_cookies:
        name = cookie.split("=")[0].strip()
        cl = cookie.lower()
        issues = []
        
        if "httponly" not in cl:
            issues.append("Missing HttpOnly — XSS can steal this cookie")
        if "secure" not in cl:
            issues.append("Missing Secure flag — sent over plain HTTP")
        if "samesite" not in cl:
            issues.append("Missing SameSite — CSRF risk")
        if "samesite=none" in cl and "secure" not in cl:
            issues.append("SameSite=None without Secure flag (invalid)")
        
        is_sensitive = any(x in name.lower() for x in ["sess", "token", "auth", "jwt", "user", "id"])
        
        if issues and is_sensitive:
            for issue in issues:
                vuln(f"Cookie '{name}': {issue}")
                findings.append({"cookie": name, "issue": issue, "severity": "HIGH"})
        elif issues:
            for issue in issues:
                med(f"Cookie '{name}': {issue}")
                findings.append({"cookie": name, "issue": issue, "severity": "MED"})
        else:
            ok(f"Cookie '{name}' — all security flags present")
    
    return findings


