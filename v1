def scan_js_secrets(target):
    section("JS FILE SECRET & SENSITIVE DATA SCAN")
    findings = []
    
    r = fetch(target)
    js_files = re.findall(r'src=["\']([^"\']*\.js[^"\']*)["\']', r["body"])
    
    base_url = target.rstrip("/")
    full_js_urls = []
    for js in js_files:
        if js.startswith("http"):
            full_js_urls.append(js)
        elif js.startswith("//"):
            full_js_urls.append("https:" + js)
        elif js.startswith("/"):
            full_js_urls.append(base_url + js)
        else:
            full_js_urls.append(base_url + "/" + js)
    
    if not full_js_urls:
        warn("No JS files found on homepage. Try authenticated endpoints manually.")
        return findings
    
    info(f"Scanning {len(full_js_urls)} JS files for secrets...")
    
    for js_url in full_js_urls[:30]:
        r = fetch(js_url, timeout=10)
        if r["status"] != 200:
            continue
        content = r["body"]
        fname = js_url.split("/")[-1][:40]
        for name, pattern in SECRET_PATTERNS.items():
            matches = re.findall(pattern, content)
            for match in matches:
                m = match if isinstance(match, str) else match[0]
                if len(m) > 5:
                    vuln(f"[{name}] in {fname}: {m[:80]}")
                    findings.append({"type": name, "file": js_url, "match": m[:100], "severity": "CRITICAL"})
    
    if not findings:
        ok("No secrets found in JS files")
    return findings


