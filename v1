def check_open_redirect(target):
    section("OPEN REDIRECT SCAN")
    
    payloads = [
        "//evil.com",
        "https://evil.com",
        "////evil.com",
        "/\\evil.com",
        "%2F%2Fevil.com",
        "javascript:alert(1)",
    ]
    
    params = ["redirect", "redirect_uri", "next", "url", "return", "returnurl",
              "return_url", "goto", "continue", "dest", "destination", "redir",
              "redirect_to", "after", "back", "callback", "forward", "location"]
    
    findings = []
    base = target.rstrip("/")
    
    for param in params:
        for payload in payloads[:3]:
            test_url = f"{base}/?{param}={urllib.parse.quote(payload, safe='')}"
            r = fetch(test_url, timeout=8)
            loc = r["headers"].get("Location", "")
            if loc and ("evil.com" in loc or "javascript" in loc.lower()):
                vuln(f"Open Redirect! param={param} → redirects to: {loc}")
                findings.append({"param": param, "payload": payload, "redirect": loc})
                break
    
    if not findings:
        ok("No open redirects found on common params")
    return findings


