def check_security_headers(target):
    section("SECURITY HEADERS AUDIT")
    r = fetch(target)
    h = {k.lower(): v for k, v in r["headers"].items()}
    findings = []

    checks = [
        ("strict-transport-security",   "HSTS missing — downgrade/MITM attacks possible",       "HIGH"),
        ("content-security-policy",     "CSP missing — XSS impact greatly amplified",            "MED"),
        ("x-frame-options",             "Clickjacking possible (no X-Frame-Options)",            "MED"),
        ("x-content-type-options",      "MIME sniffing enabled (missing X-Content-Type-Options)","LOW"),
        ("referrer-policy",             "Referrer-Policy missing — URL data leakage",            "LOW"),
        ("permissions-policy",          "Permissions-Policy missing",                            "LOW"),
    ]

    for header, msg, severity in checks:
        if header not in h:
            if severity == "HIGH": high(msg)
            elif severity == "MED": med(msg)
            else: warn(msg)
            findings.append({"header": header, "issue": msg, "severity": severity})
        else:
            ok(f"{header}: {h[header][:60]}")

    # Info disclosure headers
    for bh in ["server", "x-powered-by", "x-aspnet-version", "x-aspnetmvc-version"]:
        if bh in h:
            med(f"Info disclosure: {bh}: {h[bh]}")
            findings.append({"header": bh, "issue": f"Version disclosure: {h[bh]}", "severity": "MED"})

    return findings


