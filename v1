def discover_subdomains(domain):
    section(f"SUBDOMAIN DISCOVERY — {domain}")
    found = set()
    
    info("Querying crt.sh (certificate transparency)...")
    try:
        r = fetch(f"https://crt.sh/?q=%.{domain}&output=json", timeout=20)
        if r["status"] == 200:
            data = json.loads(r["body"])
            for entry in data:
                name = entry.get("name_value", "")
                for n in name.split("\n"):
                    n = n.strip().lstrip("*.")
                    if domain in n and " " not in n and len(n) < 100:
                        found.add(n)
        ok(f"crt.sh: {len(found)} entries")
    except Exception as e:
        warn(f"crt.sh failed: {e}")
    
    info("Querying HackerTarget...")
    try:
        r = fetch(f"https://api.hackertarget.com/hostsearch/?q={domain}", timeout=15)
        if r["status"] == 200 and "error check your" not in r["body"].lower():
            for line in r["body"].splitlines():
                if "," in line:
                    sub = line.split(",")[0].strip()
                    if domain in sub:
                        found.add(sub)
    except:
        pass

    if found:
        ok(f"Found {len(found)} unique subdomains:")
        for s in sorted(found)[:50]:
            print(f"    {C.CYAN}{s}{C.RESET}")
        if len(found) > 50:
            warn(f"...and {len(found)-50} more")
    else:
        warn("No subdomains found via passive recon")
    
    return sorted(found)


