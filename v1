def check_http_methods(target):
    section("HTTP METHOD TAMPERING")
    findings = []
    dangerous_methods = ["PUT", "DELETE", "PATCH", "TRACE", "OPTIONS", "PROPFIND", "MOVE"]
    
    for method in dangerous_methods:
        r = fetch(target, method=method, timeout=8)
        if r["status"] not in [405, 501, 403, 0]:
            if method == "TRACE" and ("TRACE" in r["body"] or r["status"] == 200):
                vuln(f"TRACE method enabled — XST (Cross-Site Tracing) possible!")
                findings.append({"method": method, "status": r["status"], "severity": "MED"})
            elif method in ["PUT", "DELETE"] and r["status"] < 400:
                high(f"{method} method returned {r['status']} — file operations may be allowed!")
                findings.append({"method": method, "status": r["status"], "severity": "HIGH"})
            elif method == "OPTIONS":
                allowed = r["headers"].get("Allow", r["headers"].get("allow", ""))
                if allowed:
                    info(f"OPTIONS Allow: {allowed}")
            else:
                med(f"{method} returned {r['status']}")
                findings.append({"method": method, "status": r["status"], "severity": "LOW"})
        else:
            ok(f"{method}: {r['status']} (properly restricted)")
    
    return findings


