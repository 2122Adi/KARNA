def check_cors(target):
    section("CORS MISCONFIGURATION SCAN")
    info(f"Testing CORS on {target}")
    domain = target.replace("https://","").replace("http://","").split("/")[0]
    
    test_origins = [
        "https://evil.com",
        f"https://{domain}.evil.com",
        f"https://evil{domain}",
        "null",
        "https://attacker.com",
    ]
    
    findings = []
    for origin in test_origins:
        r = fetch(target, extra_headers={"Origin": origin})
        acao = r["headers"].get("Access-Control-Allow-Origin", "")
        acac = r["headers"].get("Access-Control-Allow-Credentials", "")
        
        if acao == origin or acao == "*":
            if acac.lower() == "true":
                vuln(f"Critical CORS! Origin={origin} | ACAO={acao} | ACAC={acac}")
                vuln(f"  Authenticated cross-origin data theft possible!")
                findings.append({"severity": "CRITICAL", "origin": origin, "acao": acao, "acac": acac})
            elif acao == "*":
                med(f"CORS wildcard (*) set — check if sensitive data exposed")
            else:
                high(f"CORS reflects origin (no credentials): {origin}")
                findings.append({"severity": "HIGH", "origin": origin, "acao": acao})
        else:
            ok(f"Origin rejected: {origin}")
    
    if not findings:
        ok("No critical CORS issues found")
    return findings


