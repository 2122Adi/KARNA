    print(f"\n  {C.DIM}Karna by Aditya Bhosale — For authorized testing only{C.RESET}\n")


# ─────────────────────────────────────────────
#  CLI ENTRYPOINT
# ─────────────────────────────────────────────
def main():
    banner()
    
    parser = argparse.ArgumentParser(
        prog="karna",
        description="Karna — Bug Bounty Hunter | by Aditya Bhosale",
        formatter_class=argparse.RawTextHelpFormatter,
        epilog="""
Examples:
  python3 karna.py -t https://example.com --all -o report.json
  python3 karna.py -t https://example.com --cors --headers --js
  python3 karna.py -d example.com --subdomains --takeover
  python3 karna.py -t https://example.com --paths --host-header --cookies
        """
    )
    
    parser.add_argument("-t", "--target",       help="Target URL (e.g. https://example.com)")
    parser.add_argument("-d", "--domain",       help="Domain for subdomain discovery")
    parser.add_argument("--subs",               help="File with subdomains list (for takeover check)")
    parser.add_argument("-o", "--output",       help="Save JSON report to this file")
    parser.add_argument("--all",                action="store_true", help="Run ALL modules")
    parser.add_argument("--cors",               action="store_true", help="CORS misconfiguration check")
    parser.add_argument("--headers",            action="store_true", help="Security headers audit")
    parser.add_argument("--redirect",           action="store_true", help="Open redirect scan")
    parser.add_argument("--takeover",           action="store_true", help="Subdomain takeover check")
    parser.add_argument("--paths",              action="store_true", help="Sensitive file/path exposure")
    parser.add_argument("--host-header",        action="store_true", help="Host header injection")
    parser.add_argument("--js",                 action="store_true", help="JS secret scan")
    parser.add_argument("--cookies",            action="store_true", help="Cookie security audit")
    parser.add_argument("--methods",            action="store_true", help="HTTP method tampering")
    parser.add_argument("--subdomains",         action="store_true", help="Passive subdomain discovery")
    
    args = parser.parse_args()
    
    if not args.target and not args.domain:
        parser.print_help()
        sys.exit(0)
    
    all_findings = {}
    target = args.target
    if not target and args.domain:
        target = f"https://{args.domain}"
    domain = args.domain or target.replace("https://","").replace("http://","").split("/")[0]
    
    subdomains = []
    if args.subs:
        try:
            with open(args.subs) as f:
                subdomains = [line.strip() for line in f if line.strip()]
            info(f"Loaded {len(subdomains)} subdomains from {args.subs}")
        except:
            err(f"Could not read: {args.subs}")
    
    run_all = args.all
    
    try:
        if target:
            if run_all or args.cors:
                all_findings["cors"] = check_cors(target)
            if run_all or args.headers:
                all_findings["headers"] = check_security_headers(target)
            if run_all or args.redirect:
                all_findings["open_redirect"] = check_open_redirect(target)
            if run_all or args.host_header:
                all_findings["host_header"] = check_host_header(target)
            if run_all or args.paths:
                all_findings["sensitive_paths"] = check_sensitive_paths(target)
            if run_all or args.js:
                all_findings["js_secrets"] = scan_js_secrets(target)
            if run_all or args.cookies:
                all_findings["cookies"] = check_cookies(target)
            if run_all or args.methods:
                all_findings["http_methods"] = check_http_methods(target)
        
        if domain:
            if run_all or args.subdomains:
                subdomains = discover_subdomains(domain)
            if run_all or args.takeover:
                if not subdomains:
                    warn("No subdomains available for takeover check. Run --subdomains first or use --subs")
                else:
                    all_findings["takeover"] = check_subdomain_takeover(subdomains)
        
        if all_findings:
            generate_report(target or domain, all_findings, args.output)
        else:
            warn("No modules ran. Use --all or pick specific checks. See --help.")
    
    except KeyboardInterrupt:
        print(f"\n\n{C.YELLOW}  [!] Scan interrupted by user.{C.RESET}\n")
        sys.exit(0)
    except Exception as e:
        err(f"Unexpected error: {e}")
        raise

if __name__ == "__main__":
    main()
